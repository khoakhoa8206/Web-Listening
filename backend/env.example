GEMINI_API_KEY=
YOUTUBE_API_KEY=
PORT=8787

# Connection string Postgres (Neon.tech hoặc Supabase), dạng:
# postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Domain(s) Netlify của frontend, phân tách bằng dấu phẩy nếu có nhiều domain.
FRONTEND_URL=http://localhost:5173

# Mã PIN tuỳ chọn để chặn spam khi deploy công khai (để trống = tắt).
APP_PIN=

# Proxy để lấy transcript YouTube (KHÔNG BẮT BUỘC nếu dùng cách miễn phí bên dưới).
# Lý do: IP dùng chung của các nền tảng hosting này đã bị YouTube chặn ở cấp IP
# (báo lỗi "too many requests ... requires solving a captcha"), nên phải cho request
# đi qua 1 proxy khác thì mới lấy được transcript trực tiếp từ server.
# Định dạng: http://user:pass@host:port  (lấy từ Webshare.io, IPRoyal, Bright Data...)
YT_PROXY_URL=

# CÁCH MIỄN PHÍ (khuyên dùng): đặt 1 chuỗi bí mật tuỳ ý ở đây, dùng để bảo vệ route
# /api/videos/cache-transcript — cho phép nạp transcript đã lấy sẵn từ máy cá nhân
# (chạy backend/scripts/prefetch-transcript.js) vào cache, thay vì mua proxy.
PREFETCH_TOKEN=
